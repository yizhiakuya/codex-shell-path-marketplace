+pub(super) fn resolve_default_shell(
+    user_shell_override: Option<shell::Shell>,
+    windows_shell_path: Option<&AbsolutePathBuf>,
+    use_zsh_fork_shell: bool,
+    zsh_path: Option<&PathBuf>,
+) -> anyhow::Result<shell::Shell> {
+    if let Some(user_shell_override) = user_shell_override {
+        return Ok(user_shell_override);
+    }
+
+    #[cfg(windows)]
+    if let Some(windows_shell_path) = windows_shell_path {
+        return shell::get_shell_by_configured_path(windows_shell_path).ok_or_else(|| {
+            anyhow::anyhow!(
+                "configured Windows shell `{}` is not usable",
+                windows_shell_path.display()
+            )
+        });
+    }
+
+    #[cfg(not(windows))]
+    let _ = windows_shell_path;
+
+    if use_zsh_fork_shell {
+        let zsh_path = zsh_path.ok_or_else(|| {
+            anyhow::anyhow!(
+                "zsh fork feature enabled, but no packaged zsh fork is available for this install"
+            )
+        })?;
+        return shell::get_shell(shell::ShellType::Zsh, Some(zsh_path)).ok_or_else(|| {
+            anyhow::anyhow!(
+                "zsh fork feature enabled, but packaged zsh fork `{}` is not usable",
+                zsh_path.display()
+            )
+        });
+    }
+
+    Ok(shell::default_user_shell())
+}
